{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter ./artifacts/kidzy run build",
  "outputDirectory": "artifacts/kidzy/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!assets/|api/|favicon\\.ico|icon\\.svg|manifest\\.webmanifest|sw\\.js|workbox-.*).*)", "destination": "/index.html" }
  ]
}
