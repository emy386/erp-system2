# ─── Supabase (required for database) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── AI Features ───
GEMINI_API_KEY=your-gemini-api-key

# ─── API Security ───
EXTRACT_API_KEY=your-extract-api-key

# Important: MUST be set in Vercel environment vars (with VITE_ prefix)
# for Supabase write operations to work
VITE_DB_PROXY_KEY=your-db-proxy-key

# ─── Database (local / direct) ───
DATABASE_URL=postgresql://user:pass@localhost:5432/db

# ─── Mobile (Expo) ───
EXPO_PUBLIC_DOMAIN=http://localhost:5173
EXPO_PUBLIC_DB_PROXY_KEY=your-db-proxy-key
